{
  "name": "smart-farmer-assistant",
  "version": "1.0.0",
  "description": "Smart Farmer Assistant - A platform for Indian farmers",
  "main": "server/index.js",
  "scripts": {
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "server": "cd server && npm run dev",
    "client": "cd client && npm run dev",
    "install:client": "npm --prefix client install",
    "install:server": "npm --prefix server install",
    "build:client": "npm --prefix client run build",
    "build": "npm install && npm run install:client && npm run install:server && npm run build:client",
    "start": "node server/index.js"
  },
  "keywords": ["farming", "agriculture", "india", "voice-assistant"],
  "author": "Smart Farmer Team",
  "license": "MIT",
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
